services:
  zam-caddy:
    image: caddy:2-alpine
    container_name: zam-self-host-caddy
    restart: unless-stopped
    ports:
{% if zam_install_mode == "local_only" %}
      - "127.0.0.1:{{ zam_app_port }}:80"
{% elif zam_install_mode == "direct_caddy" %}
      - "80:80"
      - "443:443"
{% else %}
      - "{{ zam_app_port }}:80"
{% endif %}
    volumes:
      - ./app:/srv/zam:ro
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1/"]
      interval: 30s
      timeout: 5s
      retries: 3

{% if zam_install_portainer | lower in ["yes", "y", "true", "1"] %}
  portainer:
    image: portainer/portainer-ce:2.21.5-alpine
    container_name: zam-portainer
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer-data:/data
    ports:
      - "127.0.0.1:9000:9000"
{% endif %}

volumes:
  caddy-data:
  caddy-config:
{% if zam_install_portainer | lower in ["yes", "y", "true", "1"] %}
  portainer-data:
{% endif %}

