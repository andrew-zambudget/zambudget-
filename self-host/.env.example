# Zam static app container
ZAM_APP_PORT=8080

# Public app origin for a local lab.
# Production example: https://app.example.com
ZAM_PUBLIC_APP_ORIGIN=http://localhost:8080

# Self-hosted Supabase-compatible backend.
# In the local lab, run `npx supabase start` and copy the API URL/anon key it prints.
ZAM_SUPABASE_URL=http://localhost:54321
ZAM_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Billing is disabled by default for personal self-hosting.
ZAM_BILLING_ENABLED=false
ZAM_BILLING_MODE=self-host-disabled

# Future production backend secrets.
# Do not commit real values.
POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-at-least-32-random-characters
SUPABASE_ANON_KEY=replace-with-generated-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt

# Magic-link email. Required if self-hosted auth sends email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=auth@example.com
SMTP_PASSWORD=replace-with-provider-token
SMTP_SENDER_NAME=Zam
SMTP_SENDER_EMAIL=auth@example.com

# OAuth is optional for self-hosting.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
