{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "zambudget-app",
  "compatibility_date": "2026-06-11",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "app.zambudget.com",
      "custom_domain": true
    }
  ]
}
